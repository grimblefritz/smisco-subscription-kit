# Per-directory filter rules read by rsync when invoked with -F
# (equivalently --filter=': /.rsync-filter').
#
# Excludes paths that should never be deployed to a webhost target:
# repo plumbing, local-only configuration, the deploy-target symlink itself,
# scratch directories, and editor / OS junk.
- /CLAUDE.md
- /.git/
- /.gitignore
- /.rsync-filter
- /www
- /working/
- /composer.lock
- /phpunit.xml
- /tests/
- /.phpunit.cache/
- /.phpunit.result.cache
- /.claude/
- .DS_Store
- Thumbs.db
- *.swp
- *.swo
- .idea/
- .vscode/
