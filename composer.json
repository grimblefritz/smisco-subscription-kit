{
    "name": "smisco/subscription-kit",
    "description": "Smisco Subscription Kit for Stripe — a host-agnostic Stripe-backed subscription model (Checkout, Portal, webhook receiver, access gate) shared across smisco apps.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "stripe/stripe-php": "^17.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Smisco\\SubscriptionKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Smisco\\SubscriptionKit\\Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "tests/run.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
